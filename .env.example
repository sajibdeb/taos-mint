# ==========================================
# Taoscriptions TAO-20 Minter Bot — Config
# ==========================================
# Copy this file to .env and fill in your values.

# ---- WALLET ----
# Your Bittensor wallet mnemonic phrase (12 or 24 words)
# For multiple wallets, separate with a pipe character |
MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# ---- TOKEN TO MINT ----
# The TAO-20 token tick (e.g. TSCR, TAOS, etc.)
TICK=TAOS

# Amount to mint per transaction
AMOUNT=420

# ---- MINTING CONFIG ----
# Total number of mint transactions to send per wallet
TOTAL_TX=10

# Delay between transactions in milliseconds (1000 = 1 second)
DELAY_MS=1000

# ---- NETWORK ----
# Bittensor mainnet WebSocket RPC endpoint
RPC_URL=wss://entrypoint-finney.opentensor.ai:443
